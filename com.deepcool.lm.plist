<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.deepcool.lm</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/deepcool-lm</string>
        <string>monitor</string>
        <string>--interval</string>
        <string>2</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/var/log/deepcool-lm.log</string>

    <key>StandardErrorPath</key>
    <string>/var/log/deepcool-lm.err</string>
</dict>
</plist>